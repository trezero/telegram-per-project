{
  "name": "telegram-per-project",
  "description": "Telegram channel for Claude Code with per-project bot isolation — each project gets its own bot, access policy, and message inbox.",
  "version": "1.1.0",
  "author": {
    "name": "trezero"
  },
  "repository": "https://github.com/trezero/telegram-per-project",
  "license": "MIT",
  "keywords": [
    "telegram",
    "messaging",
    "channel",
    "mcp",
    "per-project",
    "multi-bot"
  ],
  "channels": [
    {
      "server": "telegram",
      "userConfig": {
        "bot_token": {
          "description": "Telegram bot token from @BotFather (e.g. 123456789:AAH...)",
          "sensitive": true
        }
      }
    }
  ],
  "mcpServers": {
    "telegram": {
      "command": "bun",
      "args": ["server.ts"],
      "cwd": "${CLAUDE_PLUGIN_ROOT}",
      "env": {
        "NODE_PATH": "${CLAUDE_PLUGIN_DATA}/node_modules"
      }
    }
  }
}
