#!/usr/bin/env bash
set -euo pipefail

# claude-bot — Session launcher & watchdog for Claude Code with Telegram notifications.
# Launches Claude Code with the Telegram channel plugin, monitors for exit,
# notifies all allowFrom users via Telegram when the session dies, and retries
# with backoff.

VERSION="1.0.0"

# Defaults
DSP=""
MAX_RETRIES=3
COOLDOWN=10
PROJECT_DIR="."
STABILITY_THRESHOLD=300  # 5 minutes in seconds

usage() {
  cat <<'EOF'
Usage: claude-bot [options] [project-dir]

Launches Claude Code with the Telegram channel plugin, monitors the process,
sends Telegram notifications on session death, and retries with backoff.

Options:
  -dsp          Add --dangerously-skip-permissions to the claude command
  --retries N   Max consecutive restart attempts (default: 3, 0 = no restart)
  --cooldown S  Seconds between restarts (default: 10)
  -h, --help    Show usage

Arguments:
  project-dir   Directory to run in (default: current directory)

Examples:
  claude-bot
  claude-bot -dsp
  claude-bot --retries 0 ~/projects/archon
  tmux new -s archon "claude-bot -dsp ~/projects/archon"
EOF
}

die() { printf 'claude-bot: %s\n' "$1" >&2; exit 1; }

# ── Parse arguments ──────────────────────────────────────────────────────────

while [[ $# -gt 0 ]]; do
  case "$1" in
    -dsp)          DSP="--dangerously-skip-permissions"; shift ;;
    --retries)     [[ -n "${2:-}" ]] || die "--retries requires a number"; MAX_RETRIES="$2"; shift 2 ;;
    --cooldown)    [[ -n "${2:-}" ]] || die "--cooldown requires a number"; COOLDOWN="$2"; shift 2 ;;
    -h|--help)     usage; exit 0 ;;
    -*)            die "unknown option: $1" ;;
    *)             PROJECT_DIR="$1"; shift ;;
  esac
done

# Validate numeric args
[[ "$MAX_RETRIES" =~ ^[0-9]+$ ]] || die "--retries must be a non-negative integer"
[[ "$COOLDOWN" =~ ^[0-9]+$ ]]    || die "--cooldown must be a non-negative integer"

# ── Resolve project context ──────────────────────────────────────────────────

PROJECT_DIR="$(cd "$PROJECT_DIR" 2>/dev/null && pwd)" || die "project directory not found: $PROJECT_DIR"

GLOBAL_STATE_DIR="$HOME/.claude/channels/telegram"
PROJECT_ID=""
STATE_DIR="$GLOBAL_STATE_DIR"

# Extract TELEGRAM_PROJECT_ID from .claude/settings.local.json (jq-free)
SETTINGS_FILE="$PROJECT_DIR/.claude/settings.local.json"
if [[ -f "$SETTINGS_FILE" ]]; then
  # Minimal JSON extraction: find "TELEGRAM_PROJECT_ID" : "value"
  PROJECT_ID=$(sed -n 's/.*"TELEGRAM_PROJECT_ID"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$SETTINGS_FILE" | head -1)
fi

if [[ -n "$PROJECT_ID" ]]; then
  STATE_DIR="$GLOBAL_STATE_DIR/projects/$PROJECT_ID"
fi

# ── Validate ─────────────────────────────────────────────────────────────────

command -v claude >/dev/null 2>&1 || die "claude not found on PATH"
command -v curl   >/dev/null 2>&1 || die "curl not found on PATH"

ENV_FILE="$STATE_DIR/.env"
[[ -f "$ENV_FILE" ]] || die "bot token not found: $ENV_FILE
  Run /telegram:configure to set up the bot token first."

# Read bot token from .env file
BOT_TOKEN=""
while IFS= read -r line || [[ -n "$line" ]]; do
  if [[ "$line" =~ ^TELEGRAM_BOT_TOKEN=(.+)$ ]]; then
    BOT_TOKEN="${BASH_REMATCH[1]}"
  fi
done < "$ENV_FILE"

[[ -n "$BOT_TOKEN" ]] || die "TELEGRAM_BOT_TOKEN not found in $ENV_FILE"

# Read allowFrom from access.json
ACCESS_FILE="$STATE_DIR/access.json"
NOTIFY_USERS=()

if [[ -f "$ACCESS_FILE" ]]; then
  # Extract allowFrom array values (jq-free): match quoted strings after "allowFrom"
  in_allow=false
  while IFS= read -r line; do
    if [[ "$line" =~ \"allowFrom\" ]]; then
      in_allow=true
      continue
    fi
    if $in_allow; then
      if [[ "$line" =~ \] ]]; then
        break
      fi
      # Extract quoted string value
      if [[ "$line" =~ \"([^\"]+)\" ]]; then
        NOTIFY_USERS+=("${BASH_REMATCH[1]}")
      fi
    fi
  done < "$ACCESS_FILE"
fi

[[ ${#NOTIFY_USERS[@]} -gt 0 ]] || die "no users in allowFrom to notify — pair with the bot first.
  Access file: $ACCESS_FILE"

# ── Telegram notification helper ─────────────────────────────────────────────

send_telegram() {
  local text="$1"
  for user_id in "${NOTIFY_USERS[@]}"; do
    curl -s -o /dev/null "https://api.telegram.org/bot${BOT_TOKEN}/sendMessage" \
      -d chat_id="$user_id" \
      --data-urlencode text="$text" || true
  done
}

# ── Signal handling ──────────────────────────────────────────────────────────

CLAUDE_PID=""
CLEAN_EXIT=false

forward_signal() {
  CLEAN_EXIT=true
  if [[ -n "$CLAUDE_PID" ]] && kill -0 "$CLAUDE_PID" 2>/dev/null; then
    kill -"$1" "$CLAUDE_PID" 2>/dev/null || true
    wait "$CLAUDE_PID" 2>/dev/null || true
  fi
  exit 0
}

trap 'forward_signal INT'  INT
trap 'forward_signal TERM' TERM

# ── Build the command ────────────────────────────────────────────────────────

build_display_cmd() {
  local cmd="claude-bot"
  [[ -n "$DSP" ]] && cmd="$cmd -dsp"
  cmd="$cmd $PROJECT_DIR"
  printf '%s' "$cmd"
}

DISPLAY_CMD=$(build_display_cmd)

# ── Main loop ────────────────────────────────────────────────────────────────

retries_left=$MAX_RETRIES
attempt=0

while true; do
  attempt=$((attempt + 1))

  CLAUDE_CMD=(claude --channels plugin:trezero/telegram-per-project)
  [[ -n "$DSP" ]] && CLAUDE_CMD+=("$DSP")

  if [[ $attempt -eq 1 ]]; then
    if [[ -n "$PROJECT_ID" ]]; then
      printf 'claude-bot: starting session (project: %s)\n' "$PROJECT_ID" >&2
    else
      printf 'claude-bot: starting session (global)\n' >&2
    fi
  else
    printf 'claude-bot: restarting session (attempt %d, %d retries left)\n' "$attempt" "$retries_left" >&2
  fi

  start_time=$(date +%s)

  # Launch Claude Code in the foreground
  CLEAN_EXIT=false
  cd "$PROJECT_DIR"
  "${CLAUDE_CMD[@]}" &
  CLAUDE_PID=$!
  wait "$CLAUDE_PID" 2>/dev/null
  exit_code=$?
  CLAUDE_PID=""

  # If we received SIGINT/SIGTERM, exit cleanly without notification
  if $CLEAN_EXIT; then
    exit 0
  fi

  end_time=$(date +%s)
  session_duration=$((end_time - start_time))

  # Stability heuristic: if session ran for >5 minutes, reset retry counter
  if [[ $session_duration -ge $STABILITY_THRESHOLD ]]; then
    retries_left=$MAX_RETRIES
  fi

  # Check if retries are available
  if [[ $MAX_RETRIES -eq 0 ]] || [[ $retries_left -le 0 ]]; then
    if [[ $MAX_RETRIES -gt 0 ]]; then
      send_telegram "Claude Code session failed to restart after $MAX_RETRIES attempt(s). Please re-authenticate (/login) and run \`$DISPLAY_CMD\` again."
    else
      send_telegram "Claude Code session has ended (exit code: $exit_code). To restart, run:

$DISPLAY_CMD"
    fi
    printf 'claude-bot: session ended (exit code: %d), no retries left\n' "$exit_code" >&2
    exit "$exit_code"
  fi

  # Notify and retry
  retries_left=$((retries_left - 1))

  send_telegram "Claude Code session has ended (exit code: $exit_code). Restarting in ${COOLDOWN}s ($((retries_left)) retries left)..."

  printf 'claude-bot: session exited (code %d), restarting in %ds\n' "$exit_code" "$COOLDOWN" >&2
  sleep "$COOLDOWN"
done
